if __name__ == '__main__':
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s [%(levelname)s] %(message)s'
    )

    def on_reconnect():
        print("  [!] Reconnected - you may want to re-home the robot.")

    print("=" * 55)
    print("UGIR L0 - ESP32 Driver Test")
    print("=" * 55)

    driver = ESP32Driver(
        port='COM9',
        max_retries=3,
        reconnect_attempts=None,   # None = infinite (unattended mode)
        on_reconnect=on_reconnect
    )

    r = driver.connect()
    print(f"Connect: {r}")
    if not r.ok:
        print("Cannot connect. Check COM9 and ESP32 power.")
        exit(1)

    # Home
    print("\n[1] Homing...")
    r = driver.home()
    print(f"    {r}")

    if not r.ok:
        print("Homing failed. Check limit switches.")
        driver.disconnect()
        exit(1)

    # Single stroke: L shape
    print("\n[2] Drawing L shape...")
    r = driver.draw_stroke([
        (0.0,  0.0),
        (0.0, 30.0),
        (15.0, 30.0),
    ], speed=12000)
    print(f"    {r}")

    # Multiple strokes
    print("\n[3] Drawing U shape (3 strokes)...")
    r = driver.draw_strokes([
        [(25.0, 0.0), (25.0, 30.0)],
        [(40.0, 0.0), (40.0, 30.0)],
        [(25.0, 30.0), (40.0, 30.0)],
    ], speed=12000)
    print(f"    {r}")

    # Position
    pos = driver.get_position()
    print(f"\n[4] Current position: {pos}")

    # Park
    print("\n[5] Parking...")
    r = driver.pen_park()
    print(f"    {r}")

    driver.disconnect()
    print("\nDone.")
