#  快速测试入口
#  python esp32_driver.py
# ══════════════════════════════════════════

if __name__ == '__main__':
    logging.basicConfig(
        level=logging.DEBUG,
        format='%(asctime)s [%(levelname)s] %(message)s'
    )

    print("=" * 50)
    print("UGIR L0 · ESP32 驱动测试")
    print("=" * 50)

    with ESP32Driver('COM9') as robot:

        # 1. 归零
        print("\n[1] 归零...")
        robot.home()

        # 2. 画第一笔：L形
        print("\n[2] 画 L 形笔画...")
        robot.draw_stroke([
            (0.0,  0.0),
            (0.0, 30.0),
            (15.0, 30.0),
        ], speed=12000)

        # 3. 画第二笔：U形（多笔画示例）
        print("\n[3] 画 U 形（两条线段）...")
        robot.draw_strokes([
            [(25.0, 0.0), (25.0, 30.0)],    # 左竖
            [(40.0, 0.0), (40.0, 30.0)],    # 右竖
            [(25.0, 30.0), (40.0, 30.0)],   # 底横
        ], speed=12000)

        # 4. 查询位置
        pos = robot.get_position()
        print(f"\n[4] 当前位置: {pos}")

        # 5. 停靠
        print("\n[5] 停靠...")
        robot.pen_park()

        print("\n✓ 测试完成")
