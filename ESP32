  Serial.println("READY");
}

// ==================== 主循环 ====================

void loop() {
  updateServo();
  processMove();
  
  if (waitingForDwellComplete) {
    if (micros() - dwellStartTime >= (uint32_t)dwellDuration * 1000UL) {
      waitingForDwellComplete = false;
      Serial.println("DWELL_COMPLETE");
      if (currentTask.active) {
        systemState = STATE_EXECUTING;
        executeNextCommand();
      }
    }
  }
  
  if (waitingForMoveComplete) {
    waitingForMoveComplete = false;
    if (currentTask.active) executeNextCommand();
  }
  
  if (waitingForHomeComplete) {
    waitingForHomeComplete = false;
    if (currentTask.active) executeNextCommand();
    else {
      systemState = STATE_IDLE;
      Serial.println("READY");
    }
  }
  
  while (Serial.available()) {
    char c = (char)Serial.read();
    if (c == '\n') {
      inputBuffer[bufferIndex] = '\0';
      
      if (strcmp(inputBuffer, "TEST") == 0) {
        testPulse();
        bufferIndex = 0;
        break;
      }
      
      if (systemState == STATE_IDLE || systemState == STATE_EXECUTING) {
        char cmd[1024];
        strcpy(cmd, inputBuffer);
        bufferIndex = 0;
        processCommand(cmd);
      } else {
        stringComplete = true;
      }
      break;
    } else if (c != '\r' && bufferIndex < sizeof(inputBuffer) - 1) {
      inputBuffer[bufferIndex++] = c;
    }
  }
  
  if (stringComplete && systemState == STATE_IDLE) {
    char cmd[1024];
    strcpy(cmd, inputBuffer);
    bufferIndex = 0;
    stringComplete = false;
    processCommand(cmd);
  }
}
