/*
 * ============================================================
 * 双轴写字机器人控制器 - ESP32-S3稳定版（增大串口缓冲区）
 * 功能：非阻塞脉冲方式，脉冲宽度20us，Z轴10°/110°
 * ============================================================
 */

// ===== 电机参数 =====
#define MICROSTEPS 32           // 驱动器细分：32细分

// ===== 电子齿轮 =====
#define PULSE_PER_MM 800.0      // 800脉冲/mm
#define PULSE_PER_MM_INT 800    // 整数版本

// ===== 速度参数 =====
#define MAX_SPEED 30000         // 最大30000 Hz
#define MIN_SPEED 100           // 最小100 Hz
#define HOME_SPEED 2000         // 归零速度2000 Hz

// ===== 加速度参数 =====
#define ACCEL_TABLE_SIZE 100    // 加速度表大小
#define ACCEL_STEPS 150         // 加速步数
#define START_SPEED_DIV 5       // 起始速度 = 目标速度 / 5

// ===== 任务参数 =====
#define MAX_TASK_SIZE 96        // 32条指令/任务
#define HOME_TIMEOUT 60000      // 归零超时(ms)
#define MAX_DELAY_TIME 10000    // 最大延时(ms)

// ===== 引脚定义 =====
#define X_STEP_PIN 4
#define X_DIR_PIN 5
#define X_ENABLE_PIN 6
#define X_LIMIT_MIN 7

#define Y_STEP_PIN 8
#define Y_DIR_PIN 9
#define Y_ENABLE_PIN 10
#define Y_LIMIT_MIN 11

#define Z_SERVO_PIN 17

// ===== 舵机角度 =====
#define Z_UP_ANGLE 0           // 笔抬起角度 10°
#define Z_DOWN_ANGLE 115        // 笔放下角度 110°

// ===== 舵机参数 =====
#define SERVO_MIN_PULSE 500
#define SERVO_MAX_PULSE 2500
#define SERVO_PERIOD 20000
#define SERVO_SETTLE_TIME 300
#define SERVO_PULSE_COUNT 8

// ===== 系统参数 =====
#define STEP_PULSE_WIDTH 20      // 脉冲宽度20us
#define SERIAL_BAUD 115200
#define SERIAL_RX_BUFFER_SIZE 2048  // 接收缓冲区2048字节
#define SERIAL_TX_BUFFER_SIZE 2048  // 发送缓冲区2048字节

// ===== 方向常量 =====
#define DIR_POSITIVE HIGH
#define DIR_NEGATIVE LOW

// ===== 非阻塞脉冲状态 =====
struct PulseState {
  bool active;
  uint32_t startTime;
  bool xPending;
  bool yPending;
  bool xStepDone;
  bool yStepDone;
};

PulseState pulseState = {false, 0, false, false, false, false};

// ===== 轴状态 =====
struct AxisState {
  uint8_t stepPin;
  uint8_t dirPin;
  uint8_t enablePin;
  uint8_t limitPin;
  volatile int32_t currentPosition;
  bool homed;
  bool enabled;
  int8_t currentDirection;
};

struct ZAxisState {
  bool isUp;
  int upAngle;
  int downAngle;
  int currentAngle;
  int targetAngle;
  uint32_t lastPulseTime;
  uint32_t lastMoveTime;
  bool moving;
};

enum CommandType {
  CMD_G01 = 1,
  CMD_G04 = 2,
  CMD_G28 = 3,
  CMD_M03 = 4,
  CMD_M05 = 5
};

struct Command {
  int32_t x, y;
  uint16_t f;
  uint16_t dwell;
  uint8_t type;
};

struct Task {
  Command commands[MAX_TASK_SIZE];
  uint16_t commandCount;
  uint16_t currentIndex;
  bool active;
  char taskId[20];
};

struct MoveState {
  int32_t targetX, targetY;
  int32_t dx, dy, steps, err;
  volatile uint32_t step_count;
  
  uint16_t target_interval;
  volatile uint16_t current_interval;
  uint16_t start_interval;
  
  uint16_t target_speed;
  int8_t step_x, step_y;
  
  volatile bool active;
  uint32_t lastStepTime;
  uint32_t nextStepTime;
  
  uint16_t accel_half;
  uint16_t accel_phase;
  uint8_t move_phase;
};

// ===== 全局变量 =====
AxisState xAxis = {X_STEP_PIN, X_DIR_PIN, X_ENABLE_PIN, X_LIMIT_MIN, 0, false, false, 0};
AxisState yAxis = {Y_STEP_PIN, Y_DIR_PIN, Y_ENABLE_PIN, Y_LIMIT_MIN, 0, false, false, 0};
ZAxisState zAxis = {true, Z_UP_ANGLE, Z_DOWN_ANGLE, Z_UP_ANGLE, Z_UP_ANGLE, 0, 0, false};
Task currentTask = {0};
MoveState moveState = {0};

uint16_t accel_table[ACCEL_TABLE_SIZE + 1];

char inputBuffer[1024];
uint16_t bufferIndex = 0;
bool stringComplete = false;

enum SystemState {
  STATE_IDLE, 
  STATE_HOMING, 
  STATE_MOVING, 
  STATE_EXECUTING, 
  STATE_Z_MOVING, 
  STATE_DWELL
};

SystemState systemState = STATE_IDLE;
bool waitingForMoveComplete = false;
bool waitingForHomeComplete = false;
bool waitingForZComplete = false;
bool waitingForDwellComplete = false;

uint32_t dwellStartTime = 0;
uint16_t dwellDuration = 0;

